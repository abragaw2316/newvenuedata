# ─────────────────────────────────────────────────────────────────────────────
# Public-Data-API-Business — repo-root ignore rules
#
# licensesignal/ keeps its own .gitignore (Next/node rules scoped to that subtree).
# IMPORTANT: the generated site data is committed ON PURPOSE — the deploy needs it
# and the pipeline does not run on Vercel. Do NOT add to this file:
#   • licensesignal/data/*.json            (the ~35 MB API dataset the routes serve)
#   • licensesignal/lib/real-data.ts
#   • licensesignal/lib/signals.ts
# ─────────────────────────────────────────────────────────────────────────────

# Dependencies (any level)
node_modules/

# Next.js / build output (any level)
.next/
out/
build/
*.tsbuildinfo
next-env.d.ts

# Vercel
.vercel/

# Test artifacts
coverage/
test-results/
playwright-report/
playwright/.cache/

# Data-pipeline raw + intermediate extracts — regenerated by `npm run refresh`.
# NOT shipped to deploy; the API serves the committed licensesignal/data/*.json.
data-pipeline/data/

# Local env / secrets
.env
.env*.local

# Local (machine-specific) Claude Code settings
.claude/settings.local.json
licensesignal/.claude/settings.local.json

# OS / editor cruft
.DS_Store
Thumbs.db
*.log
npm-debug.log*

# Stale memory file for a DIFFERENT project (life-expenses) that landed in this
# folder — kept out of the repo. Left on disk; delete it yourself if you want.
/project-life-expenses.md
